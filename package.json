{
  "name": "jamago-security",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=26.0.0",
    "npm": ">=8.0.0"
  },
  "description": "Jama Go Security marketing website built with Angular.",
  "scripts": {
    "ng": "node scripts/run-with-node.mjs ng",
    "setup:node": "node scripts/setup-node.mjs",
    "predev": "node scripts/setup-node.mjs",
    "prestart": "node scripts/setup-node.mjs",
    "prebuild": "node scripts/setup-node.mjs",
    "dev": "node scripts/run-with-node.mjs ng serve",
    "start": "node scripts/run-with-node.mjs ng serve",
    "build": "node scripts/run-with-node.mjs ng build",
    "deploy": "powershell -ExecutionPolicy Bypass -File scripts/deploy.ps1",
    "watch": "node scripts/run-with-node.mjs ng build --watch --configuration development",
    "preview": "node scripts/run-with-node.mjs ng serve --configuration production"
  },
  "dependencies": {
    "@angular/common": "^22.0.6",
    "@angular/compiler": "^22.0.6",
    "@angular/core": "^22.0.6",
    "@angular/forms": "^22.0.6",
    "@angular/platform-browser": "^22.0.6",
    "@angular/platform-browser-dynamic": "^22.0.6",
    "@angular/router": "^22.0.6",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "~0.16.2"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^22.0.6",
    "@angular/cli": "^22.0.6",
    "@angular/compiler-cli": "^22.0.6",
    "typescript": "~6.0.3"
  }
}
